{
  "name": "codelens-ai",
  "version": "1.0.0",
  "description": "AST-graph code analysis with Tree-sitter and Neo4j",
  "main": "dist/cli.js",
  "bin": {
    "ast-graph": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "analyze": "ts-node src/cli.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "neo4j:start": "docker-compose up -d neo4j",
    "neo4j:stop": "docker-compose stop neo4j"
  },
  "keywords": [
    "code-analysis",
    "static-analysis",
    "ast",
    "tree-sitter",
    "neo4j",
    "graph-database",
    "knowledge-graph",
    "code-intelligence",
    "javascript",
    "typescript",
    "java"
  ],
  "author": "CodeLens AI Contributors",
  "license": "MIT",
  "homepage": "https://github.com/marvikomo/code-lens-aI#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marvikomo/code-lens-aI.git"
  },
  "bugs": {
    "url": "https://github.com/marvikomo/code-lens-aI/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^16.5.0",
    "graphlib": "^2.1.8",
    "neo4j-driver": "^5.28.1",
    "tree-sitter": "^0.22.4",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5"
  }
}
